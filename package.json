{
  "name": "speech-to-text-v1",
  "version": "0.1.0",
  "private": true,
  "description": "v1 macOS speech-to-text app",
  "main": "out/main/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git@github.com:massun-onibakuchi/speech-to-text-app.git"
  },
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "pnpm run build && electron-builder",
    "dist:mac": "pnpm run build && electron-builder --mac pkg --publish never",
    "release:checklist": "cat docs/release-checklist.md",
    "release:dry-run": "bash scripts/release-dry-run.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "contract:smoke": "node scripts/provider-contract-smoke.mjs",
    "test:e2e": "pnpm run build && if command -v xvfb-run >/dev/null 2>&1; then xvfb-run -a playwright test; else playwright test; fi",
    "test:e2e:headed": "pnpm run build && if command -v xvfb-run >/dev/null 2>&1; then xvfb-run -a playwright test --headed; else playwright test --headed; fi"
  },
  "build": {
    "appId": "com.example.speechtotext",
    "productName": "SpeechToText",
    "files": [
      "out/**",
      "resources/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/sounds",
        "to": "sounds",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/tray",
        "to": "tray",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/whispercpp",
        "to": "whispercpp",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "icon": "resources/icon/dock-icon.png",
      "target": [
        "pkg"
      ],
      "hardenedRuntime": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "22.10.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "2.1.8",
    "electron": "38.0.0",
    "electron-builder": "26.0.12",
    "electron-vite": "4.0.0",
    "jsdom": "24.1.3",
    "playwright": "^1.58.2",
    "typescript": "5.7.3",
    "vite": "6.0.7",
    "vitest": "2.1.8"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@ricky0123/vad-web": "0.0.30",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "lucide-react": "^0.575.0",
    "onnxruntime-web": "1.24.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
