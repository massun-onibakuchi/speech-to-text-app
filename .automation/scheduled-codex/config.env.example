# Where: .automation/scheduled-codex/config.env.example
# What: Example host-side environment for the scheduled Codex container run.
# Why: launchd has a minimal environment, so values needed by Docker should be declared explicitly.

# GitHub CLI token available to commands run inside the container.
GH_TOKEN=replace-with-github-token

# Human-readable label included in scheduled run reports.
TAKOPI_PROJECT_ALIAS=replace-with-project-alias

# Optional Telegram delivery for scheduled start and post-run notifications.
# Set both values together to send a start notification before Docker and a report after each run.
# TELEGRAM_BOT_TOKEN=123456:replace-with-bot-token
# TELEGRAM_CHAT_ID=-1001234567890

# Optional explicit git identity for scheduler-authored commits.
# If omitted, the host repo's current git user.name/user.email are forwarded.
# Use an email address linked to your GitHub account, or your GitHub noreply email.
# SCHEDULED_CODEX_GIT_USER_NAME=your-github-name
# SCHEDULED_CODEX_GIT_USER_EMAIL=123456+your-user@users.noreply.github.com

# Optional override if you want a different local image tag.
# SCHEDULED_CODEX_IMAGE_TAG=speech-to-text-scheduled-codex:local
